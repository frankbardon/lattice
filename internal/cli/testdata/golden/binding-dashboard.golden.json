{
  "manifest": {
    "description": "An item bound to an http connection by id, carrying a variable-filled query, plus a $secret reference in the connection config. Run: METRICS_API_TOKEN=xyz dashspec resolve examples/binding-dashboard.json — the resolved token value never appears in the output.",
    "formatVersion": "1.0.0",
    "id": "binding-example",
    "title": "Direct Binding + Secret Refs Example"
  },
  "root": {
    "id": "root",
    "type": {
      "ref": "https://lattice.dev/schemas/items/container/1.0.0",
      "id": "https://lattice.dev/schemas/items/container/1.0.0",
      "name": "container",
      "version": "1.0.0"
    },
    "container": true,
    "config": {
      "grid": {
        "columns": [
          1
        ]
      }
    },
    "layout": {
      "columns": [
        1
      ],
      "rows": [
        1
      ],
      "gap": 0,
      "placements": [
        {
          "colStart": 1,
          "colSpan": 1,
          "rowStart": 1,
          "rowSpan": 1
        }
      ]
    },
    "children": [
      {
        "id": "metrics-table",
        "type": {
          "ref": "https://lattice.dev/schemas/items/table/1.0.0",
          "id": "https://lattice.dev/schemas/items/table/1.0.0",
          "name": "table",
          "version": "1.0.0"
        },
        "container": false,
        "config": {
          "connectionId": "metrics-api",
          "query": {
            "hours": 24,
            "label": "last 24h",
            "region": "us-east"
          },
          "title": "Metrics for us-east"
        },
        "varEnv": {
          "region": {
            "name": "region",
            "type": "string",
            "default": "us-east",
            "declaredAt": "doc"
          },
          "window": {
            "name": "window",
            "type": "integer",
            "default": 24,
            "declaredAt": "doc"
          }
        },
        "binding": {
          "connectionId": "metrics-api",
          "query": {
            "hours": 24,
            "label": "last 24h",
            "region": "us-east"
          },
          "contract": {
            "itemType": "table",
            "connectionId": "metrics-api",
            "expectedResult": {
              "description": "Result-shape contract (E4-S3): a JSON Schema fragment describing the rows a bound connection is expected to return. The resolver validates that this fragment is well-formed when the table declares a connectionId, and validates inline static-connection data against it. It is a schema-level keyword (not per-instance config) and is ignored by JSON Schema config validation. A table's result is an array of non-empty row objects whose cells are non-null scalars (a stricter shape than the static connection's own config schema, which also permits null cells).",
              "items": {
                "additionalProperties": {
                  "type": [
                    "string",
                    "number",
                    "boolean"
                  ]
                },
                "minProperties": 1,
                "type": "object"
              },
              "type": "array"
            }
          }
        }
      }
    ],
    "varEnv": {
      "region": {
        "name": "region",
        "type": "string",
        "default": "us-east",
        "declaredAt": "doc"
      },
      "window": {
        "name": "window",
        "type": "integer",
        "default": 24,
        "declaredAt": "doc"
      }
    }
  },
  "connections": [
    {
      "id": "metrics-api",
      "type": {
        "ref": "https://lattice.dev/schemas/connections/http/1.0.0",
        "id": "https://lattice.dev/schemas/connections/http/1.0.0",
        "name": "http",
        "version": "1.0.0"
      },
      "config": {
        "headers": {
          "Authorization": {
            "$secret": "METRICS_API_TOKEN"
          }
        },
        "method": "GET",
        "url": "https://api.example.com/metrics"
      },
      "secrets": [
        "METRICS_API_TOKEN"
      ]
    }
  ]
}
