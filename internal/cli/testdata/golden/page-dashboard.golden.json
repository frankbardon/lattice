{
  "manifest": {
    "description": "A page-like dashboard: a single body region of block-wrapped content leaves — a heading, two markdown prose paragraphs, and a captioned image — that reads like an article. Two document-scope variables (productName, releaseVersion) are interpolated into the heading and the prose via ${var} to demonstrate that content text is carried verbatim with variables substituted. Run: lattice resolve examples/page-dashboard.json. Structured under the page-content grammar (root -\u003e body region -\u003e block -\u003e content leaf).",
    "formatVersion": "1.0.0",
    "id": "page-example",
    "title": "Page-like Content Example"
  },
