                    "label": "Level",
                    "constraints": {
                      "description": "The semantic heading depth, an integer in the inclusive range 1-6 (1 = top-level section heading, 6 = deepest). Required with no default — a value below 1, above 6, or non-integer fails config validation."
                    },
                    "rendering": "number-field"
                  },
                  {
                    "field": "text",
                    "type": "string",
                    "label": "Text",
                    "constraints": {
