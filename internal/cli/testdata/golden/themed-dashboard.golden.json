{
  "manifest": {
    "author": "Lattice",
    "description": "Demonstrates the three theme/grammar constructs of this effort side by side (E2 + E3-S2): a document-scope DEFAULT theme, a per-WRAPPER theme override on one block (a partial subset that overrides only some tokens; the resolver attaches it verbatim alongside the default with NO cascade/merge), and a VARIABLE-BOX region holding a variable widget directly. The body region places a variable-box of controls above two block-wrapped tables — one inheriting the document default theme wholesale, one carrying its own override. Conforms to https://lattice.dev/schemas/dashboard/1.0.0.",
    "formatVersion": "1.0.0",
    "id": "example-themed",
    "title": "Theme Layers + Variable Box Example"
  },
  "root": {
    "id": "root",
    "type": {
      "ref": "https://lattice.dev/schemas/items/container/1.0.0",
      "id": "https://lattice.dev/schemas/items/container/1.0.0",
      "name": "container",
      "version": "1.0.0"
    },
    "container": true,
    "config": {
      "grid": {
        "columns": [
          1
        ]
      }
    },
    "layout": {
      "columns": [
        1
      ],
      "rows": [
        1
      ],
      "gap": 0,
      "placements": [
        {
          "colStart": 1,
          "colSpan": 1,
          "rowStart": 1,
          "rowSpan": 1
        }
      ]
    },
    "children": [
      {
        "id": "body",
        "type": {
          "ref": "https://lattice.dev/schemas/items/container/1.0.0",
          "id": "https://lattice.dev/schemas/items/container/1.0.0",
          "name": "container",
          "version": "1.0.0"
        },
        "container": true,
        "config": {
          "grid": {
            "columns": [
              1,
              1
            ],
            "gap": 1,
            "rows": [
              1,
              2
            ]
          }
        },
        "layout": {
          "columns": [
            0.5,
            0.5
          ],
          "rows": [
            0.3333333333333333,
            0.6666666666666666
          ],
          "gap": 1,
          "placements": [
            {
              "colStart": 1,
              "colSpan": 2,
              "rowStart": 1,
              "rowSpan": 1
            },
            {
              "colStart": 1,
              "colSpan": 1,
              "rowStart": 2,
              "rowSpan": 1
            },
            {
              "colStart": 2,
              "colSpan": 1,
              "rowStart": 2,
              "rowSpan": 1
            }
          ]
        },
        "children": [
          {
            "id": "controls",
            "type": {
              "ref": "https://lattice.dev/schemas/items/variable-box/1.0.0",
              "id": "https://lattice.dev/schemas/items/variable-box/1.0.0",
              "name": "variable-box",
              "version": "1.0.0"
            },
            "container": false,
            "config": {
              "arrangement": "inline"
            },
            "placement": {
              "colSpan": 2,
              "colStart": 1,
              "rowStart": 1
            },
            "children": [
              {
                "id": "region-picker",
                "type": {
                  "ref": "https://lattice.dev/schemas/items/select/1.0.0",
                  "id": "https://lattice.dev/schemas/items/select/1.0.0",
                  "name": "select",
                  "version": "1.0.0"
                },
                "container": false,
                "config": {
                  "label": "Region",
                  "options": [
                    {
                      "label": "United States",
                      "value": "us"
                    },
                    {
                      "label": "Europe",
                      "value": "eu"
                    },
                    {
                      "label": "Asia-Pacific",
                      "value": "apac"
                    }
                  ],
                  "variable": "region"
                },
                "varEnv": {
                  "region": {
                    "name": "region",
                    "type": "enum",
                    "default": "us",
                    "options": [
                      "us",
                      "eu",
                      "apac"
                    ],
                    "declaredAt": "doc"
                  }
                },
                "surface": [
                  {
                    "field": "disabled",
                    "type": "boolean",
                    "label": "Disabled",
                    "constraints": {
                      "description": "When true the control is rendered read-only — editable at runtime to gate the input."
                    },
                    "rendering": "toggle"
                  },
                  {
                    "field": "label",
                    "type": "string",
                    "label": "Label",
                    "constraints": {
                      "description": "The human label rendered beside the control — editable at runtime."
                    },
                    "rendering": "text-input"
                  },
                  {
                    "field": "sort",
                    "type": "enum",
                    "label": "Option sort",
                    "constraints": {
                      "description": "How the option set is ordered for display — editable at runtime.",
                      "enum": [
                        "declared",
                        "label",
                        "value"
                      ]
                    },
                    "rendering": "select"
                  }
                ]
              }
            ],
            "varEnv": {
              "region": {
                "name": "region",
                "type": "enum",
                "default": "us",
                "options": [
                  "us",
                  "eu",
                  "apac"
                ],
                "declaredAt": "doc"
              }
            },
            "surface": [
              {
                "field": "arrangement",
                "type": "enum",
                "label": "Arrangement",
                "constraints": {
                  "description": "How the box arranges its variable widgets — editable at runtime. `stacked` lays them out one per row; `inline` flows them along a single row. Semantic and renderer-agnostic: NO CSS units or keywords."
                },
                "rendering": "segmented"
              }
            ]
          },
          {
            "id": "default-themed-block",
            "type": {
              "ref": "https://lattice.dev/schemas/items/block/1.0.0",
              "id": "https://lattice.dev/schemas/items/block/1.0.0",
              "name": "block",
              "version": "1.0.0"
            },
            "container": false,
            "config": {
              "id": "default-themed-block",
              "title": "Inherits Document Theme"
            },
            "placement": {
              "colStart": 1,
              "rowStart": 2
            },
            "children": [
              {
                "id": "default-themed",
                "type": {
                  "ref": "https://lattice.dev/schemas/items/table/1.0.0",
                  "id": "https://lattice.dev/schemas/items/table/1.0.0",
                  "name": "table",
                  "version": "1.0.0"
                },
                "container": false,
                "config": {
                  "columns": [
                    {
                      "header": "Metric"
                    },
                    {
                      "header": "Value"
                    }
                  ],
                  "rows": [
                    [
                      "latency",
                      "live"
                    ]
                  ],
                  "title": "Default-themed for us"
                },
                "varEnv": {
                  "region": {
                    "name": "region",
                    "type": "enum",
                    "default": "us",
                    "options": [
                      "us",
                      "eu",
                      "apac"
                    ],
                    "declaredAt": "doc"
                  }
                },
                "surface": [
                  {
                    "field": "columns",
                    "type": "array",
                    "label": "Columns",
                    "constraints": {
                      "description": "The table's column definitions (E3-S2 surface). Editable at runtime to control which columns are shown and in what order. Each entry is a column object with a required header label.",
                      "items": {
                        "properties": {
                          "header": {
                            "minLength": 1,
                            "type": "string"
                          }
                        },
                        "required": [
                          "header"
                        ],
                        "type": "object"
                      }
                    }
                  },
                  {
                    "field": "query",
                    "type": "array",
                    "label": "Query parameters",
                    "constraints": {
                      "description": "The query parameters passed to the table's bound connection (E3-S2 surface). Editable at runtime to re-parameterize the fetch. Requires a connectionId; parameter values may reference variables via $var / ${} bindings, filled by the resolver's interpolation pass before binding."
                    }
                  },
                  {
                    "field": "title",
                    "type": "string",
                    "label": "Title",
                    "constraints": {
                      "description": "The heading rendered above the table — editable at runtime."
                    },
                    "rendering": "text-input"
                  }
                ]
              }
            ],
            "varEnv": {
              "region": {
                "name": "region",
                "type": "enum",
                "default": "us",
                "options": [
                  "us",
                  "eu",
                  "apac"
                ],
                "declaredAt": "doc"
              }
            },
            "surface": [
              {
                "field": "title",
                "type": "string",
                "label": "Title",
                "constraints": {
                  "description": "The block's human heading/label — editable at runtime."
                },
                "rendering": "text-input"
              },
              {
                "field": "visibility",
                "type": "boolean",
                "label": "Visible",
                "constraints": {
                  "description": "Whether the block (and the content it wraps) is shown — editable at runtime to toggle the block on or off."
                },
                "rendering": "toggle"
              }
            ]
          },
          {
            "id": "overridden-block",
            "type": {
              "ref": "https://lattice.dev/schemas/items/block/1.0.0",
              "id": "https://lattice.dev/schemas/items/block/1.0.0",
              "name": "block",
              "version": "1.0.0"
            },
            "container": false,
            "config": {
              "id": "overridden-block",
              "theme": {
                "emphasis": "high",
                "tone": "accent"
              },
              "title": "Per-Wrapper Theme Override"
            },
            "placement": {
              "colStart": 2,
              "rowStart": 2
            },
            "children": [
              {
                "id": "overridden",
                "type": {
                  "ref": "https://lattice.dev/schemas/items/table/1.0.0",
                  "id": "https://lattice.dev/schemas/items/table/1.0.0",
                  "name": "table",
                  "version": "1.0.0"
                },
                "container": false,
                "config": {
                  "columns": [
                    {
                      "header": "Metric"
                    },
                    {
                      "header": "Value"
                    }
                  ],
                  "rows": [
                    [
                      "errors",
                      "live"
                    ]
                  ],
                  "title": "Overridden for us"
                },
                "varEnv": {
                  "region": {
                    "name": "region",
                    "type": "enum",
                    "default": "us",
                    "options": [
                      "us",
                      "eu",
                      "apac"
                    ],
                    "declaredAt": "doc"
                  }
                },
                "surface": [
                  {
                    "field": "columns",
                    "type": "array",
                    "label": "Columns",
                    "constraints": {
                      "description": "The table's column definitions (E3-S2 surface). Editable at runtime to control which columns are shown and in what order. Each entry is a column object with a required header label.",
                      "items": {
                        "properties": {
                          "header": {
                            "minLength": 1,
                            "type": "string"
                          }
                        },
                        "required": [
                          "header"
                        ],
                        "type": "object"
                      }
                    }
                  },
                  {
                    "field": "query",
                    "type": "array",
                    "label": "Query parameters",
                    "constraints": {
                      "description": "The query parameters passed to the table's bound connection (E3-S2 surface). Editable at runtime to re-parameterize the fetch. Requires a connectionId; parameter values may reference variables via $var / ${} bindings, filled by the resolver's interpolation pass before binding."
                    }
                  },
                  {
                    "field": "title",
                    "type": "string",
                    "label": "Title",
                    "constraints": {
                      "description": "The heading rendered above the table — editable at runtime."
                    },
                    "rendering": "text-input"
                  }
                ]
              }
            ],
            "varEnv": {
              "region": {
                "name": "region",
                "type": "enum",
                "default": "us",
                "options": [
                  "us",
                  "eu",
                  "apac"
                ],
                "declaredAt": "doc"
              }
            },
            "surface": [
              {
                "field": "title",
                "type": "string",
                "label": "Title",
                "constraints": {
                  "description": "The block's human heading/label — editable at runtime."
                },
                "rendering": "text-input"
              },
              {
                "field": "visibility",
                "type": "boolean",
                "label": "Visible",
                "constraints": {
                  "description": "Whether the block (and the content it wraps) is shown — editable at runtime to toggle the block on or off."
                },
                "rendering": "toggle"
              }
            ]
          }
        ],
        "varEnv": {
          "region": {
            "name": "region",
            "type": "enum",
            "default": "us",
            "options": [
              "us",
              "eu",
              "apac"
            ],
            "declaredAt": "doc"
          }
        },
        "surface": [
          {
            "field": "grid",
            "type": "array",
            "label": "Grid tracks",
            "constraints": {
              "description": "The container's relative-weight grid (E3-S2 surface). Editable at runtime: the column track weights, the row track weights, and the inter-track gap — all unitless, relative numbers. Column and row weights are positive-number arrays the resolver normalizes to fractions summing to 1 per axis; gap is a non-negative number in the same relative space. NO CSS units or keywords.",
              "fields": {
                "columns": {
                  "items": {
                    "exclusiveMinimum": 0,
                    "type": "number"
                  },
                  "minItems": 1,
                  "type": "array"
                },
                "gap": {
                  "minimum": 0,
                  "type": "number"
                },
                "rows": {
                  "items": {
                    "exclusiveMinimum": 0,
                    "type": "number"
                  },
                  "minItems": 1,
                  "type": "array"
                }
              }
            }
          }
        ]
      }
    ],
    "varEnv": {
      "region": {
        "name": "region",
        "type": "enum",
        "default": "us",
        "options": [
          "us",
          "eu",
          "apac"
        ],
        "declaredAt": "doc"
      }
    },
    "surface": [
      {
        "field": "grid",
        "type": "array",
        "label": "Grid tracks",
        "constraints": {
          "description": "The container's relative-weight grid (E3-S2 surface). Editable at runtime: the column track weights, the row track weights, and the inter-track gap — all unitless, relative numbers. Column and row weights are positive-number arrays the resolver normalizes to fractions summing to 1 per axis; gap is a non-negative number in the same relative space. NO CSS units or keywords.",
          "fields": {
            "columns": {
              "items": {
                "exclusiveMinimum": 0,
                "type": "number"
              },
              "minItems": 1,
              "type": "array"
            },
            "gap": {
              "minimum": 0,
              "type": "number"
            },
            "rows": {
              "items": {
                "exclusiveMinimum": 0,
                "type": "number"
              },
              "minItems": 1,
              "type": "array"
            }
          }
        }
      }
    ]
  },
  "defaultTheme": {
    "emphasis": "low",
    "spacing": "cosy",
    "tone": "neutral"
  },
  "scopeSurfaces": {
    "$connections": [],
    "$manifest": [
      {
        "field": "description",
        "type": "string",
        "label": "Description",
        "constraints": {
          "description": "An optional longer-form description of the dashboard."
        },
        "rendering": "textarea"
      },
      {
        "field": "title",
        "type": "string",
        "label": "Title",
        "constraints": {
          "description": "The dashboard's human-readable title."
        },
        "rendering": "text-input"
      }
    ],
    "$root": [],
    "$theme": [
      {
        "field": "border",
        "type": "enum",
        "label": "Border Weight",
        "constraints": {
          "description": "How present a separating edge is around the styled surface.",
          "enum": [
            "none",
            "hairline",
            "standard"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "density",
        "type": "enum",
        "label": "Density",
        "constraints": {
          "description": "How tightly repeated/listed content is packed.",
          "enum": [
            "comfortable",
            "compact"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "emphasis",
        "type": "enum",
        "label": "Emphasis",
        "constraints": {
          "description": "How prominent the styled element appears.",
          "enum": [
            "none",
            "low",
            "high"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "radius",
        "type": "enum",
        "label": "Corner Radius",
        "constraints": {
          "description": "How softened the corners of the styled surface are.",
          "enum": [
            "none",
            "subtle",
            "rounded"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "spacing",
        "type": "enum",
        "label": "Spacing",
        "constraints": {
          "description": "The relative amount of internal/outer breathing room.",
          "enum": [
            "compact",
            "cosy",
            "roomy"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "tone",
        "type": "enum",
        "label": "Tone",
        "constraints": {
          "description": "The semantic colour intent, expressed by meaning.",
          "enum": [
            "neutral",
            "accent",
            "positive",
            "caution",
            "critical"
          ]
        },
        "rendering": "select"
      }
    ],
    "$variables": []
  }
}
