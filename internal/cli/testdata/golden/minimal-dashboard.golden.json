{
  "manifest": {
    "author": "Lattice",
    "description": "A hand-written fixture: a root container holding two static tables. Conforms to https://lattice.dev/schemas/dashboard/1.0.0.",
    "formatVersion": "1.0.0",
    "id": "example-minimal",
    "title": "Minimal Example Dashboard"
  },
  "root": {
    "id": "root",
    "type": {
      "ref": "https://lattice.dev/schemas/items/container/1.0.0",
      "id": "https://lattice.dev/schemas/items/container/1.0.0",
      "name": "container",
      "version": "1.0.0"
    },
    "container": true,
    "config": {
      "grid": {
        "columns": [
          1,
          1
        ],
        "gap": 1,
        "rows": [
          1
        ]
      }
    },
    "layout": {
      "columns": [
        0.5,
        0.5
      ],
      "rows": [
        1
      ],
      "gap": 1,
      "placements": [
        {
          "colStart": 1,
          "colSpan": 1,
          "rowStart": 1,
          "rowSpan": 1
        },
        {
          "colStart": 2,
          "colSpan": 1,
          "rowStart": 1,
          "rowSpan": 1
        }
      ]
    },
    "children": [
      {
        "id": "fruits",
        "type": {
          "ref": "https://lattice.dev/schemas/items/table/1.0.0",
          "id": "https://lattice.dev/schemas/items/table/1.0.0",
          "name": "table",
          "version": "1.0.0"
        },
        "container": false,
        "config": {
          "columns": [
            {
              "header": "Name"
            },
            {
              "header": "Color"
            }
          ],
          "rows": [
            [
              "Apple",
              "Red"
            ],
            [
              "Banana",
              "Yellow"
            ]
          ],
          "title": "Fruits"
        },
        "placement": {
          "colSpan": 1,
          "colStart": 1,
          "rowSpan": 1,
          "rowStart": 1
        }
      },
      {
        "id": "metrics",
        "type": {
          "ref": "https://lattice.dev/schemas/items/table/1.0.0",
          "id": "https://lattice.dev/schemas/items/table/1.0.0",
          "name": "table",
          "version": "1.0.0"
        },
        "container": false,
        "config": {
          "columns": [
            {
              "header": "Metric"
            },
            {
              "header": "Value"
            }
          ],
          "rows": [
            [
              "Requests",
              "1024"
            ],
            [
              "Errors",
              "3"
            ]
          ],
          "title": "Metrics"
        },
        "placement": {
          "colSpan": 1,
          "colStart": 2,
          "rowSpan": 1,
          "rowStart": 1
        }
      }
    ]
  }
}
