{
  "manifest": {
    "description": "A block-wrapped table bound to a static connection whose inline rows conform to the table's expectedResult result-shape contract (E4-S3). Run: lattice resolve examples/contract-dashboard.json — resolution succeeds and the binding carries the resolved contract (item type, connection id, expected result). Structured under the E3-S2 grammar (root -\u003e body region -\u003e block -\u003e table).",
    "formatVersion": "1.0.0",
    "id": "contract-example",
    "title": "Result-Shape Contract Example"
  },
  "root": {
    "id": "root",
    "type": {
      "ref": "https://lattice.dev/schemas/items/container/1.0.0",
      "id": "https://lattice.dev/schemas/items/container/1.0.0",
      "name": "container",
      "version": "1.0.0"
    },
    "container": true,
    "config": {
      "grid": {
        "columns": [
          1
        ]
      }
    },
    "layout": {
      "columns": [
        1
      ],
      "rows": [
        1
      ],
      "gap": 0,
      "placements": [
        {
          "colStart": 1,
          "colSpan": 1,
          "rowStart": 1,
          "rowSpan": 1
        }
      ]
    },
    "children": [
      {
        "id": "body",
        "type": {
          "ref": "https://lattice.dev/schemas/items/container/1.0.0",
          "id": "https://lattice.dev/schemas/items/container/1.0.0",
          "name": "container",
          "version": "1.0.0"
        },
        "container": true,
        "config": {
          "grid": {
            "columns": [
              1
            ]
          }
        },
        "layout": {
          "columns": [
            1
          ],
          "rows": [
            1
          ],
          "gap": 0,
          "placements": [
            {
              "colStart": 1,
              "colSpan": 1,
              "rowStart": 1,
              "rowSpan": 1
            }
          ]
        },
        "children": [
          {
            "id": "fruit-block",
            "type": {
              "ref": "https://lattice.dev/schemas/items/block/1.0.0",
              "id": "https://lattice.dev/schemas/items/block/1.0.0",
              "name": "block",
              "version": "1.0.0"
            },
            "container": false,
            "config": {
              "id": "fruit-block"
            },
            "children": [
              {
                "id": "fruit-table",
                "type": {
                  "ref": "https://lattice.dev/schemas/items/table/1.0.0",
                  "id": "https://lattice.dev/schemas/items/table/1.0.0",
                  "name": "table",
                  "version": "1.0.0"
                },
                "container": false,
                "config": {
                  "connectionId": "inline-fruits",
                  "title": "Fruit Inventory"
                },
                "binding": {
                  "connectionId": "inline-fruits",
                  "contract": {
                    "itemType": "table",
                    "connectionId": "inline-fruits",
                    "expectedResult": {
                      "description": "Result-shape contract (E4-S3): a JSON Schema fragment describing the rows a bound connection is expected to return. The resolver validates that this fragment is well-formed when the table declares a connectionId, and validates inline static-connection data against it. It is a schema-level keyword (not per-instance config) and is ignored by JSON Schema config validation. A table's result is an array of non-empty row objects whose cells are non-null scalars (a stricter shape than the static connection's own config schema, which also permits null cells).",
                      "items": {
                        "additionalProperties": {
                          "type": [
                            "string",
                            "number",
                            "boolean"
                          ]
                        },
                        "minProperties": 1,
                        "type": "object"
                      },
                      "type": "array"
                    }
                  }
                },
                "surface": [
                  {
                    "field": "columns",
                    "type": "array",
                    "label": "Columns",
                    "constraints": {
                      "description": "The table's column definitions (E3-S2 surface). Editable at runtime to control which columns are shown and in what order. Each entry is a column object with a required header label.",
                      "items": {
                        "properties": {
                          "header": {
                            "minLength": 1,
                            "type": "string"
                          }
                        },
                        "required": [
                          "header"
                        ],
                        "type": "object"
                      }
                    }
                  },
                  {
                    "field": "query",
                    "type": "array",
                    "label": "Query parameters",
                    "constraints": {
                      "description": "The query parameters passed to the table's bound connection (E3-S2 surface). Editable at runtime to re-parameterize the fetch. Requires a connectionId; parameter values may reference variables via $var / ${} bindings, filled by the resolver's interpolation pass before binding."
                    }
                  },
                  {
                    "field": "title",
                    "type": "string",
                    "label": "Title",
                    "constraints": {
                      "description": "The heading rendered above the table — editable at runtime."
                    },
                    "rendering": "text-input"
                  }
                ]
              }
            ],
            "surface": [
              {
                "field": "title",
                "type": "string",
                "label": "Title",
                "constraints": {
                  "description": "The block's human heading/label — editable at runtime."
                },
                "rendering": "text-input"
              },
              {
                "field": "tone",
                "type": "enum",
                "label": "Chrome",
                "constraints": {
                  "description": "The block's frame chrome, drawn from the shared theme TONE vocabulary. An omitted tone renders no chrome (a bare, frameless tile); `neutral` is the plain card; the status tones tint the card. A top-level per-block concern (not the nested `theme` override) so it is settable through the configurable-surface mechanism.",
                  "enum": [
                    "neutral",
                    "accent",
                    "positive",
                    "caution",
                    "critical"
                  ]
                },
                "rendering": "select"
              },
              {
                "field": "visibility",
                "type": "boolean",
                "label": "Visible",
                "constraints": {
                  "description": "Whether the block (and the content it wraps) is shown — editable at runtime to toggle the block on or off."
                },
                "rendering": "toggle"
              }
            ]
          }
        ],
        "surface": [
          {
            "field": "grid",
            "type": "object",
            "label": "Grid tracks",
            "constraints": {
              "description": "The container's relative-weight grid (E3-S2 surface). Editable at runtime: the column track weights, the row track weights, and the inter-track gap — all unitless, relative numbers. Column and row weights are positive-number arrays the resolver normalizes to fractions summing to 1 per axis; gap is a non-negative number in the same relative space. NO CSS units or keywords.",
              "fields": {
                "columns": {
                  "items": {
                    "exclusiveMinimum": 0,
                    "type": "number"
                  },
                  "minItems": 1,
                  "type": "array"
                },
                "gap": {
                  "minimum": 0,
                  "type": "number"
                },
                "rows": {
                  "items": {
                    "exclusiveMinimum": 0,
                    "type": "number"
                  },
                  "minItems": 1,
                  "type": "array"
                }
              }
            }
          },
          {
            "field": "grid.columns",
            "path": [
              "grid",
              "columns"
            ],
            "type": "array",
            "label": "Column tracks",
            "constraints": {
              "description": "The container grid's column track weights (E2-S1 nested surface): a positive-number array the resolver normalizes to fractions summing to 1, editable on its own without touching the row tracks or the gap. NO CSS units or keywords."
            }
          },
          {
            "field": "grid.gap",
            "path": [
              "grid",
              "gap"
            ],
            "type": "number",
            "label": "Track gap",
            "constraints": {
              "description": "The container grid's inter-track gap (E2-S1 nested surface): a non-negative, unitless number in the same relative space as the track weights, editable on its own without touching the column/row tracks. NO CSS units or keywords."
            },
            "rendering": "number-field"
          },
          {
            "field": "grid.rows",
            "path": [
              "grid",
              "rows"
            ],
            "type": "array",
            "label": "Row tracks",
            "constraints": {
              "description": "The container grid's row track weights (E2-S1 nested surface): a positive-number array the resolver normalizes to fractions summing to 1, editable on its own without touching the column tracks or the gap. NO CSS units or keywords."
            }
          }
        ]
      }
    ],
    "surface": [
      {
        "field": "grid",
        "type": "object",
        "label": "Grid tracks",
        "constraints": {
          "description": "The container's relative-weight grid (E3-S2 surface). Editable at runtime: the column track weights, the row track weights, and the inter-track gap — all unitless, relative numbers. Column and row weights are positive-number arrays the resolver normalizes to fractions summing to 1 per axis; gap is a non-negative number in the same relative space. NO CSS units or keywords.",
          "fields": {
            "columns": {
              "items": {
                "exclusiveMinimum": 0,
                "type": "number"
              },
              "minItems": 1,
              "type": "array"
            },
            "gap": {
              "minimum": 0,
              "type": "number"
            },
            "rows": {
              "items": {
                "exclusiveMinimum": 0,
                "type": "number"
              },
              "minItems": 1,
              "type": "array"
            }
          }
        }
      },
      {
        "field": "grid.columns",
        "path": [
          "grid",
          "columns"
        ],
        "type": "array",
        "label": "Column tracks",
        "constraints": {
          "description": "The container grid's column track weights (E2-S1 nested surface): a positive-number array the resolver normalizes to fractions summing to 1, editable on its own without touching the row tracks or the gap. NO CSS units or keywords."
        }
      },
      {
        "field": "grid.gap",
        "path": [
          "grid",
          "gap"
        ],
        "type": "number",
        "label": "Track gap",
        "constraints": {
          "description": "The container grid's inter-track gap (E2-S1 nested surface): a non-negative, unitless number in the same relative space as the track weights, editable on its own without touching the column/row tracks. NO CSS units or keywords."
        },
        "rendering": "number-field"
      },
      {
        "field": "grid.rows",
        "path": [
          "grid",
          "rows"
        ],
        "type": "array",
        "label": "Row tracks",
        "constraints": {
          "description": "The container grid's row track weights (E2-S1 nested surface): a positive-number array the resolver normalizes to fractions summing to 1, editable on its own without touching the column tracks or the gap. NO CSS units or keywords."
        }
      }
    ]
  },
  "connections": [
    {
      "id": "inline-fruits",
      "type": {
        "ref": "https://lattice.dev/schemas/connections/static/1.0.0",
        "id": "https://lattice.dev/schemas/connections/static/1.0.0",
        "name": "static",
        "version": "1.0.0"
      },
      "config": {
        "columns": [
          "name",
          "qty"
        ],
        "rows": [
          {
            "name": "apple",
            "qty": 3
          },
          {
            "name": "pear",
            "qty": 7
          },
          {
            "name": "kiwi",
            "qty": 12
          }
        ]
      }
    }
  ],
  "scopeSurfaces": {
    "$connections": [],
    "$manifest": [
      {
        "field": "description",
        "type": "string",
        "label": "Description",
        "constraints": {
          "description": "An optional longer-form description of the dashboard."
        },
        "rendering": "textarea"
      },
      {
        "field": "title",
        "type": "string",
        "label": "Title",
        "constraints": {
          "description": "The dashboard's human-readable title."
        },
        "rendering": "text-input"
      }
    ],
    "$root": [],
    "$theme": [
      {
        "field": "border",
        "type": "enum",
        "label": "Border Weight",
        "constraints": {
          "description": "How present a separating edge is around the styled surface.",
          "enum": [
            "none",
            "hairline",
            "standard"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "density",
        "type": "enum",
        "label": "Density",
        "constraints": {
          "description": "How tightly repeated/listed content is packed.",
          "enum": [
            "comfortable",
            "compact"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "emphasis",
        "type": "enum",
        "label": "Emphasis",
        "constraints": {
          "description": "How prominent the styled element appears.",
          "enum": [
            "none",
            "low",
            "high"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "radius",
        "type": "enum",
        "label": "Corner Radius",
        "constraints": {
          "description": "How softened the corners of the styled surface are.",
          "enum": [
            "none",
            "subtle",
            "rounded"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "spacing",
        "type": "enum",
        "label": "Spacing",
        "constraints": {
          "description": "The relative amount of internal/outer breathing room.",
          "enum": [
            "compact",
            "cosy",
            "roomy"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "tone",
        "type": "enum",
        "label": "Tone",
        "constraints": {
          "description": "The semantic colour intent, expressed by meaning.",
          "enum": [
            "neutral",
            "accent",
            "positive",
            "caution",
            "critical"
          ]
        },
        "rendering": "select"
      }
    ],
    "$variables": []
  }
}
