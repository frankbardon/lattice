{
  "manifest": {
    "author": "Lattice",
    "description": "Focused E3 example covering all three variable kinds in one document: a static string variable (env), a runtime-settable integer with a default (window), and a computed variable derived from the others via an expr (heading). The variables feed both a ${} string template and {\"$var\"} typed bindings on a descendant table. The resolved tree carries each node's varEnv (the variables in scope, with their resolved defaults and declaredAt). Conforms to https://lattice.dev/schemas/dashboard/1.0.0.",
    "formatVersion": "1.0.0",
    "id": "example-variables",
    "title": "Variables: Static, Runtime \u0026 Computed Example"
  },
  "root": {
    "id": "root",
    "type": {
      "ref": "https://lattice.dev/schemas/items/container/1.0.0",
      "id": "https://lattice.dev/schemas/items/container/1.0.0",
      "name": "container",
      "version": "1.0.0"
    },
    "container": true,
    "config": {
      "grid": {
        "columns": [
          1
        ],
        "rows": [
          1
        ]
      }
    },
    "layout": {
      "columns": [
        1
      ],
      "rows": [
        1
      ],
      "gap": 0,
      "placements": [
        {
          "colStart": 1,
          "colSpan": 1,
          "rowStart": 1,
          "rowSpan": 1
        }
      ]
    },
    "children": [
      {
        "id": "report",
        "type": {
          "ref": "https://lattice.dev/schemas/items/table/1.0.0",
          "id": "https://lattice.dev/schemas/items/table/1.0.0",
          "name": "table",
          "version": "1.0.0"
        },
        "container": false,
        "config": {
          "columns": [
            {
              "header": "Variable"
            },
            {
              "header": "Value"
            }
          ],
          "rows": [
            [
              "env",
              "prod"
            ],
            [
              "window",
              "12"
            ],
            [
              "heading",
              "[prod] last 12h"
            ]
          ],
          "title": "[prod] last 12h"
        },
        "placement": {
          "colSpan": 1,
          "colStart": 1,
          "rowSpan": 1,
          "rowStart": 1
        },
        "varEnv": {
          "env": {
            "name": "env",
            "type": "string",
            "default": "prod",
            "declaredAt": "doc"
          },
          "heading": {
            "name": "heading",
            "type": "string",
            "default": "[prod] last 12h",
            "expr": "\"[\" + env + \"] last \" + string(window) + \"h\"",
            "declaredAt": "doc"
          },
          "window": {
            "name": "window",
            "type": "integer",
            "default": 12,
            "declaredAt": "doc"
          }
        },
        "surface": [
          {
            "field": "columns",
            "type": "array",
            "label": "Columns",
            "constraints": {
              "description": "The table's column definitions (E3-S2 surface). Editable at runtime to control which columns are shown and in what order. Each entry is a column object with a required header label.",
              "items": {
                "properties": {
                  "header": {
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "required": [
                  "header"
                ],
                "type": "object"
              }
            }
          },
          {
            "field": "query",
            "type": "array",
            "label": "Query parameters",
            "constraints": {
              "description": "The query parameters passed to the table's bound connection (E3-S2 surface). Editable at runtime to re-parameterize the fetch. Requires a connectionId; parameter values may reference variables via $var / ${} bindings, filled by the resolver's interpolation pass before binding."
            }
          },
          {
            "field": "title",
            "type": "string",
            "label": "Title",
            "constraints": {
              "description": "The heading rendered above the table — editable at runtime."
            },
            "rendering": "text-input"
          }
        ]
      }
    ],
    "varEnv": {
      "env": {
        "name": "env",
        "type": "string",
        "default": "prod",
        "declaredAt": "doc"
      },
      "heading": {
        "name": "heading",
        "type": "string",
        "default": "[prod] last 12h",
        "expr": "\"[\" + env + \"] last \" + string(window) + \"h\"",
        "declaredAt": "doc"
      },
      "window": {
        "name": "window",
        "type": "integer",
        "default": 12,
        "declaredAt": "doc"
      }
    },
    "surface": [
      {
        "field": "grid",
        "type": "array",
        "label": "Grid tracks",
        "constraints": {
          "description": "The container's relative-weight grid (E3-S2 surface). Editable at runtime: the column track weights, the row track weights, and the inter-track gap — all unitless, relative numbers. Column and row weights are positive-number arrays the resolver normalizes to fractions summing to 1 per axis; gap is a non-negative number in the same relative space. NO CSS units or keywords.",
          "fields": {
            "columns": {
              "items": {
                "exclusiveMinimum": 0,
                "type": "number"
              },
              "minItems": 1,
              "type": "array"
            },
            "gap": {
              "minimum": 0,
              "type": "number"
            },
            "rows": {
              "items": {
                "exclusiveMinimum": 0,
                "type": "number"
              },
              "minItems": 1,
              "type": "array"
            }
          }
        }
      }
    ]
  }
}
