    "id": "root",
    "type": {
      "ref": "https://lattice.dev/schemas/items/container/1.0.0",
      "id": "https://lattice.dev/schemas/items/container/1.0.0",
      "name": "container",
      "version": "1.0.0"
    },
    "container": true,
    "config": {
      "grid": {
        "columns": [
          1,
          1
        ],
        "gap": 1,
        "rows": [
          1,
          1,
          1,
          2
        ]
      }
    },
    "layout": {
      "columns": [
        0.5,
        0.5
      ],
