{
  "manifest": {
    "author": "Lattice",
    "description": "Exercises the typed-widget catalog (E1): one widget per family binds a document-scoped variable whose declared type the widget permits, and a table consumes each variable via $var typed bindings and ${} string templates. A text-input drives a string, a slider a number, a toggle a boolean, a select an enum, and a multiselect plus a freeform tag-input each an array. Changing a control sets that variable's runtime override and re-resolves the document so the consumer updates live. The resolver enforces widget↔variable type compatibility (WIDGET_TYPE_MISMATCH on a mismatch). Conforms to https://lattice.dev/schemas/dashboard/1.0.0.",
    "formatVersion": "1.0.0",
    "id": "example-widgets",
    "title": "Typed Variable Widgets Example"
  },
