            "type": "string",
            "default": "Overview",
            "declaredAt": "doc"
          },
          "live": {
            "name": "live",
            "type": "boolean",
            "default": true,
            "declaredAt": "doc"
          },
          "metrics": {
            "name": "metrics",
            "type": "array",
