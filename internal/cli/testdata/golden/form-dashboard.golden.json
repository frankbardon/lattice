{
  "manifest": {
    "author": "Lattice",
    "description": "Exercises the `form` container in BOTH layout modes plus a standalone widget. The first form uses flow mode (compact label+control rows, split into two columns) to gather string, boolean, and enum inputs; its widgets carry no placement. The second form uses grid mode (a weighted column/row grid identical to container's) and places each widget into an explicit 1-indexed cell. Alongside the forms, a single widget stands directly in a container grid cell — no form wrapper — proving widgets are ordinary item instances. A table consumes every variable via $var typed bindings and ${} string templates, so changing any control re-resolves the document and updates the summary live. Conforms to https://lattice.dev/schemas/dashboard/1.0.0.",
    "formatVersion": "1.0.0",
    "id": "example-form",
    "title": "Form Container Example"
  },
