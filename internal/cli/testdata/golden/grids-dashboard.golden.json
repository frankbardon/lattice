  "scopeSurfaces": {
    "$connections": [],
    "$manifest": [
      {
        "field": "description",
        "type": "string",
        "label": "Description",
        "constraints": {
          "description": "An optional longer-form description of the dashboard."
        },
        "rendering": "textarea"
      },
      {
        "field": "title",
        "type": "string",
        "label": "Title",
        "constraints": {
          "description": "The dashboard's human-readable title."
        },
        "rendering": "text-input"
      }
    ],
    "$root": [],
    "$theme": [
      {
        "field": "border",
        "type": "enum",
        "label": "Border Weight",
        "constraints": {
          "description": "How present a separating edge is around the styled surface.",
          "enum": [
            "none",
            "hairline",
            "standard"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "density",
        "type": "enum",
        "label": "Density",
        "constraints": {
          "description": "How tightly repeated/listed content is packed.",
          "enum": [
            "comfortable",
            "compact"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "emphasis",
        "type": "enum",
        "label": "Emphasis",
        "constraints": {
          "description": "How prominent the styled element appears.",
          "enum": [
            "none",
            "low",
            "high"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "radius",
        "type": "enum",
        "label": "Corner Radius",
        "constraints": {
          "description": "How softened the corners of the styled surface are.",
          "enum": [
            "none",
            "subtle",
            "rounded"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "spacing",
        "type": "enum",
        "label": "Spacing",
        "constraints": {
          "description": "The relative amount of internal/outer breathing room.",
          "enum": [
            "compact",
            "cosy",
            "roomy"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "tone",
        "type": "enum",
        "label": "Tone",
        "constraints": {
          "description": "The semantic colour intent, expressed by meaning.",
          "enum": [
            "neutral",
            "accent",
            "positive",
            "caution",
            "critical"
          ]
        },
        "rendering": "select"
      }
    ],
    "$variables": []
  }
