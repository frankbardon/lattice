{
  "manifest": {
    "author": "Lattice",
    "description": "Focused E2-S1 example under the E3-S2 grammar: root holds a body region whose grid places a block-wrapped sidebar table and a nested panel container; the panel container declares its own subgrid and places its own block-wrapped children with explicit colStart/rowStart placement. Demonstrates arbitrary grid nesting and fractional track sizing; each content leaf (a table) is wrapped in a block. Resolution normalizes each container's tracks and child placements into a layout block. Conforms to https://lattice.dev/schemas/dashboard/1.0.0.",
    "formatVersion": "1.0.0",
    "id": "example-grids",
    "title": "Nested Grids \u0026 Subgrids Example"
  },
  "root": {
    "id": "root",
    "type": {
      "ref": "https://lattice.dev/schemas/items/container/1.0.0",
      "id": "https://lattice.dev/schemas/items/container/1.0.0",
      "name": "container",
      "version": "1.0.0"
    },
    "container": true,
    "config": {
      "grid": {
        "columns": [
          1
        ]
      }
    },
    "layout": {
      "columns": [
        1
      ],
      "rows": [
        1
      ],
      "gap": 0,
      "placements": [
        {
          "colStart": 1,
          "colSpan": 1,
          "rowStart": 1,
          "rowSpan": 1
        }
      ]
    },
    "children": [
      {
        "id": "body",
        "type": {
          "ref": "https://lattice.dev/schemas/items/container/1.0.0",
          "id": "https://lattice.dev/schemas/items/container/1.0.0",
          "name": "container",
          "version": "1.0.0"
        },
        "container": true,
        "config": {
          "grid": {
            "columns": [
              1,
              2
            ],
            "gap": 1,
            "rows": [
              1
            ]
          }
        },
        "layout": {
          "columns": [
            0.3333333333333333,
            0.6666666666666666
          ],
          "rows": [
            1
          ],
          "gap": 1,
          "placements": [
            {
              "colStart": 1,
              "colSpan": 1,
              "rowStart": 1,
              "rowSpan": 1
            },
            {
              "colStart": 2,
              "colSpan": 1,
              "rowStart": 1,
              "rowSpan": 1
            }
          ]
        },
        "children": [
          {
            "id": "sidebar-block",
            "type": {
              "ref": "https://lattice.dev/schemas/items/block/1.0.0",
              "id": "https://lattice.dev/schemas/items/block/1.0.0",
              "name": "block",
              "version": "1.0.0"
            },
            "container": false,
            "config": {
              "id": "sidebar-block"
            },
            "placement": {
              "colSpan": 1,
              "colStart": 1,
              "rowSpan": 1,
              "rowStart": 1
            },
            "children": [
              {
                "id": "sidebar",
                "type": {
                  "ref": "https://lattice.dev/schemas/items/table/1.0.0",
                  "id": "https://lattice.dev/schemas/items/table/1.0.0",
                  "name": "table",
                  "version": "1.0.0"
                },
                "container": false,
                "config": {
                  "columns": [
                    {
                      "header": "Link"
                    }
                  ],
                  "rows": [
                    [
                      "Home"
                    ],
                    [
                      "About"
                    ]
                  ],
                  "title": "Sidebar"
                },
                "surface": [
                  {
                    "field": "columns",
                    "type": "array",
                    "label": "Columns",
                    "constraints": {
                      "description": "The table's column definitions (E3-S2 surface). Editable at runtime to control which columns are shown and in what order. Each entry is a column object with a required header label.",
                      "items": {
                        "properties": {
                          "header": {
                            "minLength": 1,
                            "type": "string"
                          }
                        },
                        "required": [
                          "header"
                        ],
                        "type": "object"
                      }
                    }
                  },
                  {
                    "field": "query",
                    "type": "array",
                    "label": "Query parameters",
                    "constraints": {
                      "description": "The query parameters passed to the table's bound connection (E3-S2 surface). Editable at runtime to re-parameterize the fetch. Requires a connectionId; parameter values may reference variables via $var / ${} bindings, filled by the resolver's interpolation pass before binding."
                    }
                  },
                  {
                    "field": "title",
                    "type": "string",
                    "label": "Title",
                    "constraints": {
                      "description": "The heading rendered above the table — editable at runtime."
                    },
                    "rendering": "text-input"
                  }
                ]
              }
            ],
            "surface": [
              {
                "field": "title",
                "type": "string",
                "label": "Title",
                "constraints": {
                  "description": "The block's human heading/label — editable at runtime."
                },
                "rendering": "text-input"
              },
              {
                "field": "visibility",
                "type": "boolean",
                "label": "Visible",
                "constraints": {
                  "description": "Whether the block (and the content it wraps) is shown — editable at runtime to toggle the block on or off."
                },
                "rendering": "toggle"
              }
            ]
          },
          {
            "id": "panel",
