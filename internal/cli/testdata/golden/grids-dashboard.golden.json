            },
            "placement": {
              "colSpan": 1,
              "colStart": 2,
              "rowSpan": 1,
              "rowStart": 1
            },
            "layout": {
              "columns": [
                1
              ],
              "rows": [
                0.75,
                0.25
              ],
              "gap": 1,
              "placements": [
                {
                  "colStart": 1,
                  "colSpan": 1,
                  "rowStart": 1,
                  "rowSpan": 1
                },
                {
                  "colStart": 1,
                  "colSpan": 1,
                  "rowStart": 2,
                  "rowSpan": 1
                }
              ]
            },
            "children": [
              {
                "id": "main-block",
                "type": {
                  "ref": "https://lattice.dev/schemas/items/block/1.0.0",
                  "id": "https://lattice.dev/schemas/items/block/1.0.0",
                  "name": "block",
                  "version": "1.0.0"
                },
                "container": false,
                "config": {
                  "id": "main-block"
                },
                "placement": {
                  "colSpan": 1,
