{
  "manifest": {
    "author": "Lattice",
    "description": "Focused E4-S1 example declaring both connection kinds at the document scope: a static inline data source (rows embedded in config) and an http (query) connection (endpoint + request shape). Connections are declared and validated against their connection-type schemas only — never dialed (no live fetch). The query connection references its credential indirectly via secretRefs rather than inlining it. Conforms to https://lattice.dev/schemas/dashboard/1.0.0.",
    "formatVersion": "1.0.0",
    "id": "example-connections",
    "title": "Connections: Static \u0026 Query Example"
  },
  "root": {
    "id": "root",
    "type": {
      "ref": "https://lattice.dev/schemas/items/container/1.0.0",
      "id": "https://lattice.dev/schemas/items/container/1.0.0",
      "name": "container",
      "version": "1.0.0"
    },
    "container": true,
    "config": {
      "grid": {
        "columns": [
          1
        ]
      }
    },
    "layout": {
      "columns": [
        1
      ],
      "rows": [
        1
      ],
      "gap": 0,
      "placements": []
    },
    "surface": [
      {
        "field": "grid",
        "type": "array",
        "label": "Grid tracks",
        "constraints": {
          "description": "The container's relative-weight grid (E3-S2 surface). Editable at runtime: the column track weights, the row track weights, and the inter-track gap — all unitless, relative numbers. Column and row weights are positive-number arrays the resolver normalizes to fractions summing to 1 per axis; gap is a non-negative number in the same relative space. NO CSS units or keywords.",
          "fields": {
            "columns": {
              "items": {
                "exclusiveMinimum": 0,
                "type": "number"
              },
              "minItems": 1,
              "type": "array"
            },
            "gap": {
              "minimum": 0,
              "type": "number"
            },
            "rows": {
              "items": {
                "exclusiveMinimum": 0,
                "type": "number"
              },
              "minItems": 1,
              "type": "array"
            }
          }
        }
      }
    ]
  },
  "connections": [
    {
      "id": "inline-fruits",
      "type": {
        "ref": "https://lattice.dev/schemas/connections/static/1.0.0",
        "id": "https://lattice.dev/schemas/connections/static/1.0.0",
        "name": "static",
        "version": "1.0.0"
      },
      "config": {
        "columns": [
          "name",
          "color"
        ],
        "rows": [
          {
            "color": "Red",
            "name": "Apple"
          },
          {
            "color": "Yellow",
            "name": "Banana"
          }
        ]
      }
    },
    {
      "id": "metrics-api",
      "type": {
        "ref": "https://lattice.dev/schemas/connections/http/1.0.0",
        "id": "https://lattice.dev/schemas/connections/http/1.0.0",
        "name": "http",
        "version": "1.0.0"
      },
      "config": {
        "method": "GET",
        "query": {
          "window": "1h"
        },
        "url": "https://api.example.com/metrics"
      },
      "secretRefs": {
        "token": "vault://lattice/metrics-api#token"
      }
    }
  ],
  "scopeSurfaces": {
    "$connections": [],
    "$manifest": [
      {
        "field": "description",
        "type": "string",
        "label": "Description",
        "constraints": {
          "description": "An optional longer-form description of the dashboard."
        },
        "rendering": "textarea"
      },
      {
        "field": "title",
        "type": "string",
        "label": "Title",
        "constraints": {
          "description": "The dashboard's human-readable title."
        },
        "rendering": "text-input"
      }
    ],
    "$root": [],
    "$theme": [
      {
        "field": "border",
        "type": "enum",
        "label": "Border Weight",
        "constraints": {
          "description": "How present a separating edge is around the styled surface.",
          "enum": [
            "none",
            "hairline",
            "standard"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "density",
        "type": "enum",
        "label": "Density",
        "constraints": {
          "description": "How tightly repeated/listed content is packed.",
          "enum": [
            "comfortable",
            "compact"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "emphasis",
        "type": "enum",
        "label": "Emphasis",
        "constraints": {
          "description": "How prominent the styled element appears.",
          "enum": [
            "none",
            "low",
            "high"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "radius",
        "type": "enum",
        "label": "Corner Radius",
        "constraints": {
          "description": "How softened the corners of the styled surface are.",
          "enum": [
            "none",
            "subtle",
            "rounded"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "spacing",
        "type": "enum",
        "label": "Spacing",
        "constraints": {
          "description": "The relative amount of internal/outer breathing room.",
          "enum": [
            "compact",
            "cosy",
            "roomy"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "tone",
        "type": "enum",
        "label": "Tone",
        "constraints": {
          "description": "The semantic colour intent, expressed by meaning.",
          "enum": [
            "neutral",
            "accent",
            "positive",
            "caution",
            "critical"
          ]
        },
        "rendering": "select"
      }
    ],
    "$variables": []
  }
}
