{
  "manifest": {
    "description": "E1-S3 golden baseline: a block-wrapped form in GRID mode (the second of the form's two layout modes), whose widget children each carry an explicit 1-indexed placement on the form's weighted grid (reusing the same layout.Block path as container). Complements form-mixed-widgets.json (flow mode) so both form layout modes are pinned. Captures the CURRENT pre-migration resolved-tree shape of a grid-layout form.",
    "formatVersion": "1.0.0",
    "id": "form-grid-layout",
    "title": "Form With Grid Layout"
  },
  "root": {
    "id": "root",
    "type": {
      "ref": "https://lattice.dev/schemas/items/container/1.0.0",
      "id": "https://lattice.dev/schemas/items/container/1.0.0",
      "name": "container",
      "version": "1.0.0"
    },
    "container": true,
    "config": {
      "grid": {
        "columns": [
          1
        ]
      }
    },
    "layout": {
      "columns": [
        1
      ],
      "rows": [
        1
      ],
      "gap": 0,
      "placements": [
        {
          "colStart": 1,
          "colSpan": 1,
          "rowStart": 1,
          "rowSpan": 1
        }
      ]
    },
    "children": [
      {
        "id": "body",
        "type": {
          "ref": "https://lattice.dev/schemas/items/container/1.0.0",
          "id": "https://lattice.dev/schemas/items/container/1.0.0",
          "name": "container",
          "version": "1.0.0"
        },
        "container": true,
        "config": {
          "grid": {
            "columns": [
              1
            ]
          }
        },
        "layout": {
          "columns": [
            1
          ],
          "rows": [
            1
          ],
          "gap": 0,
          "placements": [
            {
              "colStart": 1,
              "colSpan": 1,
              "rowStart": 1,
              "rowSpan": 1
            }
          ]
        },
        "children": [
          {
            "id": "grid-form-block",
            "type": {
              "ref": "https://lattice.dev/schemas/items/block/1.0.0",
              "id": "https://lattice.dev/schemas/items/block/1.0.0",
              "name": "block",
              "version": "1.0.0"
            },
            "container": false,
            "config": {
              "id": "grid-form-block"
            },
            "children": [
              {
                "id": "grid-form",
                "type": {
                  "ref": "https://lattice.dev/schemas/items/form/1.0.0",
                  "id": "https://lattice.dev/schemas/items/form/1.0.0",
                  "name": "form",
                  "version": "1.0.0"
                },
                "container": false,
                "config": {
                  "layout": {
                    "columns": [
                      1,
                      1
                    ],
                    "gap": 0.5,
                    "mode": "grid"
                  }
                },
                "layout": {
                  "columns": [
                    0.5,
                    0.5
                  ],
                  "rows": [
                    1
                  ],
                  "gap": 0.5,
                  "placements": [
                    {
                      "colStart": 1,
                      "colSpan": 1,
                      "rowStart": 1,
                      "rowSpan": 1
                    },
                    {
                      "colStart": 2,
                      "colSpan": 1,
                      "rowStart": 1,
                      "rowSpan": 1
                    }
                  ]
                },
                "children": [
                  {
                    "id": "g-name",
                    "type": {
                      "ref": "https://lattice.dev/schemas/items/text-input/1.0.0",
                      "id": "https://lattice.dev/schemas/items/text-input/1.0.0",
                      "name": "text-input",
                      "version": "1.0.0"
                    },
                    "container": false,
                    "config": {
                      "label": "Name",
                      "variable": "name"
                    },
                    "placement": {
                      "colSpan": 1,
                      "colStart": 1,
                      "rowSpan": 1,
                      "rowStart": 1
                    },
                    "varEnv": {
                      "name": {
                        "name": "name",
                        "type": "string",
                        "default": "",
                        "declaredAt": "doc"
                      },
                      "size": {
                        "name": "size",
                        "type": "integer",
                        "default": 1,
                        "declaredAt": "doc"
                      }
                    },
                    "surface": [
                      {
                        "field": "disabled",
                        "type": "boolean",
                        "label": "Disabled",
                        "constraints": {
                          "description": "When true the control is rendered read-only — editable at runtime to gate the input."
                        },
                        "rendering": "toggle"
                      },
                      {
                        "field": "label",
                        "type": "string",
                        "label": "Label",
                        "constraints": {
                          "description": "The human label rendered beside the control — editable at runtime."
                        },
                        "rendering": "text-input"
                      },
                      {
                        "field": "placeholder",
                        "type": "string",
                        "label": "Placeholder",
                        "constraints": {
                          "description": "Placeholder text shown in the empty control — editable at runtime."
                        },
                        "rendering": "text-input"
                      }
                    ]
                  },
                  {
                    "id": "g-size",
                    "type": {
                      "ref": "https://lattice.dev/schemas/items/stepper/1.0.0",
                      "id": "https://lattice.dev/schemas/items/stepper/1.0.0",
                      "name": "stepper",
                      "version": "1.0.0"
                    },
                    "container": false,
                    "config": {
                      "label": "Size",
                      "max": 5,
                      "min": 1,
                      "variable": "size"
                    },
                    "placement": {
                      "colSpan": 1,
                      "colStart": 2,
                      "rowSpan": 1,
                      "rowStart": 1
                    },
                    "varEnv": {
                      "name": {
                        "name": "name",
                        "type": "string",
                        "default": "",
                        "declaredAt": "doc"
                      },
                      "size": {
                        "name": "size",
                        "type": "integer",
                        "default": 1,
                        "declaredAt": "doc"
                      }
                    },
                    "surface": [
                      {
                        "field": "disabled",
                        "type": "boolean",
                        "label": "Disabled",
                        "constraints": {
                          "description": "When true the control is rendered read-only — editable at runtime to gate the input."
                        },
                        "rendering": "toggle"
                      },
                      {
                        "field": "label",
                        "type": "string",
                        "label": "Label",
                        "constraints": {
                          "description": "The human label rendered beside the control — editable at runtime."
                        },
                        "rendering": "text-input"
                      },
                      {
                        "field": "max",
                        "type": "number",
                        "label": "Maximum",
                        "constraints": {
                          "description": "Inclusive upper bound for the entered value — editable at runtime. Must not be less than min."
                        },
                        "rendering": "number-field"
                      },
                      {
                        "field": "min",
                        "type": "number",
                        "label": "Minimum",
                        "constraints": {
                          "description": "Inclusive lower bound for the entered value — editable at runtime. Must not exceed max."
                        },
                        "rendering": "number-field"
                      },
                      {
                        "field": "step",
                        "type": "number",
                        "label": "Step",
                        "constraints": {
                          "description": "Increment between selectable values — editable at runtime. Must be a positive number."
                        },
                        "rendering": "number-field"
                      }
                    ]
                  }
                ],
                "varEnv": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "default": "",
                    "declaredAt": "doc"
                  },
                  "size": {
                    "name": "size",
                    "type": "integer",
                    "default": 1,
                    "declaredAt": "doc"
                  }
                },
                "surface": [
                  {
                    "field": "layout",
                    "type": "array",
                    "label": "Form layout",
                    "constraints": {
                      "description": "The form's layout declaration (E3-S3 surface). Editable at runtime: the layout `mode` (flow vs grid) and, in flow mode, the unitless `columns` count children pack into; in grid mode the relative-weight `columns`/`rows` track lists and `gap`. All unitless and relative — NO CSS units or keywords. Declared with the array variable type per the top-level-only surface limitation (the layout is an object whose editable sub-fields are described here, matching the container `grid` surface convention).",
                      "fields": {
                        "columns": {
                          "description": "Flow mode: a unitless integer column count (1–12). Grid mode: a positive-number relative-weight track array."
                        },
                        "gap": {
                          "minimum": 0,
                          "type": "number"
                        },
                        "mode": {
                          "enum": [
                            "flow",
                            "grid"
                          ],
                          "type": "string"
                        },
                        "rows": {
                          "items": {
                            "exclusiveMinimum": 0,
                            "type": "number"
                          },
                          "type": "array"
                        }
                      }
                    }
                  }
                ]
              }
            ],
            "varEnv": {
              "name": {
                "name": "name",
                "type": "string",
                "default": "",
                "declaredAt": "doc"
              },
              "size": {
                "name": "size",
                "type": "integer",
                "default": 1,
                "declaredAt": "doc"
              }
            },
            "surface": [
              {
                "field": "title",
                "type": "string",
                "label": "Title",
                "constraints": {
                  "description": "The block's human heading/label — editable at runtime."
                },
                "rendering": "text-input"
              },
              {
                "field": "tone",
                "type": "enum",
                "label": "Chrome",
                "constraints": {
                  "description": "The block's frame chrome, drawn from the shared theme TONE vocabulary. An omitted tone renders no chrome (a bare, frameless tile); `neutral` is the plain card; the status tones tint the card. A top-level per-block concern (not the nested `theme` override) so it is settable through the configurable-surface mechanism.",
                  "enum": [
                    "neutral",
                    "accent",
                    "positive",
                    "caution",
                    "critical"
                  ]
                },
                "rendering": "select"
              },
              {
                "field": "visibility",
                "type": "boolean",
                "label": "Visible",
                "constraints": {
                  "description": "Whether the block (and the content it wraps) is shown — editable at runtime to toggle the block on or off."
                },
                "rendering": "toggle"
              }
            ]
          }
        ],
        "varEnv": {
          "name": {
            "name": "name",
            "type": "string",
            "default": "",
            "declaredAt": "doc"
          },
          "size": {
            "name": "size",
            "type": "integer",
            "default": 1,
            "declaredAt": "doc"
          }
        },
        "surface": [
          {
            "field": "grid",
            "type": "object",
            "label": "Grid tracks",
            "constraints": {
              "description": "The container's relative-weight grid (E3-S2 surface). Editable at runtime: the column track weights, the row track weights, and the inter-track gap — all unitless, relative numbers. Column and row weights are positive-number arrays the resolver normalizes to fractions summing to 1 per axis; gap is a non-negative number in the same relative space. NO CSS units or keywords.",
              "fields": {
                "columns": {
                  "items": {
                    "exclusiveMinimum": 0,
                    "type": "number"
                  },
                  "minItems": 1,
                  "type": "array"
                },
                "gap": {
                  "minimum": 0,
                  "type": "number"
                },
                "rows": {
                  "items": {
                    "exclusiveMinimum": 0,
                    "type": "number"
                  },
                  "minItems": 1,
                  "type": "array"
                }
              }
            }
          },
          {
            "field": "grid.columns",
            "path": [
              "grid",
              "columns"
            ],
            "type": "array",
            "label": "Column tracks",
            "constraints": {
              "description": "The container grid's column track weights (E2-S1 nested surface): a positive-number array the resolver normalizes to fractions summing to 1, editable on its own without touching the row tracks or the gap. NO CSS units or keywords."
            }
          },
          {
            "field": "grid.gap",
            "path": [
              "grid",
              "gap"
            ],
            "type": "number",
            "label": "Track gap",
            "constraints": {
              "description": "The container grid's inter-track gap (E2-S1 nested surface): a non-negative, unitless number in the same relative space as the track weights, editable on its own without touching the column/row tracks. NO CSS units or keywords."
            },
            "rendering": "number-field"
          },
          {
            "field": "grid.rows",
            "path": [
              "grid",
              "rows"
            ],
            "type": "array",
            "label": "Row tracks",
            "constraints": {
              "description": "The container grid's row track weights (E2-S1 nested surface): a positive-number array the resolver normalizes to fractions summing to 1, editable on its own without touching the column tracks or the gap. NO CSS units or keywords."
            }
          }
        ]
      }
    ],
    "varEnv": {
      "name": {
        "name": "name",
        "type": "string",
        "default": "",
        "declaredAt": "doc"
      },
      "size": {
        "name": "size",
        "type": "integer",
        "default": 1,
        "declaredAt": "doc"
      }
