  "scopeSurfaces": {
    "$connections": [],
    "$manifest": [
      {
        "field": "description",
        "type": "string",
        "label": "Description",
        "constraints": {
          "description": "An optional longer-form description of the dashboard."
        },
        "rendering": "textarea"
      },
      {
        "field": "title",
        "type": "string",
        "label": "Title",
        "constraints": {
          "description": "The dashboard's human-readable title."
        },
        "rendering": "text-input"
      }
    ],
    "$root": [],
    "$theme": [
      {
        "field": "border",
        "type": "enum",
        "label": "Border Weight",
        "constraints": {
          "description": "How present a separating edge is around the styled surface.",
          "enum": [
            "none",
            "hairline",
            "standard"
          ]
        },
        "rendering": "select"
      },
      {
        "field": "density",
        "type": "enum",
        "label": "Density",
        "constraints": {
